# Copy this to ".env" and fill in whichever providers you use.

# Groq - https://console.groq.com/keys
# (Free tier; some VPS / cloud-VM IP ranges are blocked by their WAF.)
GROQ_API_KEY=

# OpenRouter - https://openrouter.ai/keys
# (Free tier with :free models, fewer IP blocks than Groq.)
OPENROUTER_API_KEY=

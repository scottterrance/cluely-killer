# Copy this to ".env" and fill in whichever providers you use.
# These keys are picked up at startup; you can also paste them in
# Settings -> AI Provider after the app is running.

# Groq - https://console.groq.com/keys
# (Free tier; some VPS / cloud-VM IP ranges are blocked by their WAF.)
GROQ_API_KEY=

# OpenRouter - https://openrouter.ai/keys
# (Free tier with :free models, fewer IP blocks than Groq.)
OPENROUTER_API_KEY=

# DeepSeek - https://platform.deepseek.com/api_keys
# Cheap paid (~$0.14/M tokens for deepseek-chat, ~$0.0005 / interview
# answer). Two models:
#   deepseek-chat     - V3, fast, OpenAI-class. Default.
#   deepseek-reasoner - R1, reasoning model. Higher quality, slower.
# Optional overrides for a custom OpenAI-compatible endpoint:
#   DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
#   DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
